import pandas as pd
from tensorflow import keras
import seaborn as sns
import matplotlib.pyplot as plt
from keras.layers import Input, Dense
from sklearn.model_selection import train_test_split
from sklearn.metrics import classification_report


df = pd.read_csv("/kaggle/input/datasets/organizations/uciml/pima-indians-diabetes-database/diabetes.csv")

df.dtypes


df.head()


sns.heatmap(df.corr(), annot=True)


sns.catplot(x="Outcome", y="Glucose", data=df, hue="Outcome", kind="box")


df["Pregnancies"].value_counts()

len(df["Pregnancies"].value_counts())

sns.histplot(x="Pregnancies", data=df, bins=50)

sns.catplot(x="Pregnancies", y="Age", data=df, kind="violin")

x = df.drop("Outcome", axis=1)
y = df["Outcome"]

x_tr, x_test, y_tr, y_test = train_test_split(x, y, test_size=0.2, stratify=y)


x_tr.shape

input_layer   = Input(shape=(8,))
hidden_layer1 = Dense(5, activation="relu")(input_layer)
hidden_layer2 = Dense(3, activation="relu")(hidden_layer1)
output_layer  = Dense(1, activation="sigmoid")(hidden_layer2)

ann_model = keras.Model(inputs=input_layer, outputs=output_layer)
ann_model.compile(optimizer="adam", loss="binary_crossentropy", metrics=["accuracy"])
ann_model.summary()

es = keras.callbacks.EarlyStopping(monitor="loss", patience=3, verbose=1)

ann_model.fit(x_tr, y_tr,
              validation_data=(x_test, y_test),
              epochs=100, callbacks=es)

ann_model.evaluate(x_test, y_test)

p = ann_model.predict(x_test)
p[0:10]

p_list = []
for i in p:
    if i >= 0.7:
        p_list.append(1)
    else:
        p_list.append(0)

print(classification_report(y_test, p_list))

pd.Series(y_tr).value_counts()

from imblearn.over_sampling import SMOTE

sm = SMOTE(sampling_strategy=1, k_neighbors=3)
x_resample, y_resample = sm.fit_resample(x_tr, y_tr)
pd.Series(y_resample).value_counts()

input_layer   = Input(shape=(8,))
hidden_layer1 = Dense(5, activation="relu")(input_layer)
hidden_layer2 = Dense(3, activation="relu")(hidden_layer1)
output_layer  = Dense(1, activation="sigmoid")(hidden_layer2)

ann_model1 = keras.Model(inputs=input_layer, outputs=output_layer)
ann_model1.compile(optimizer="adam", loss="binary_crossentropy", metrics=["accuracy"])
ann_model1.summary()


ann_model1.fit(x_resample, y_resample,
               validation_data=(x_test, y_test),
               epochs=100, callbacks=es)

p = ann_model1.predict(x_test)

p_list = []
for i in p:
    if i >= 0.7:
        p_list.append(1)
    else:
        p_list.append(0)

print(classification_report(y_test, p_list))
