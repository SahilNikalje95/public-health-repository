def backward_elimination(X, y, sl=0.05):
    selected_features = list(X.columns)
    while True:
        X_subset = X[selected_features].copy()
        X_const = sm.add_constant(X_subset, has_constant='add')
        X_const = X_const.astype(float)
        model = sm.OLS(y, X_const).fit()
        pvals = model.pvalues.drop('const')
        if pvals.max() > sl:
            worst_feature = pvals.idxmax()
            selected_features.remove(worst_feature)
        else:
            break
    final_X_subset = X[selected_features].copy()
    final_X = sm.add_constant(final_X_subset, has_constant='add')
    final_X = final_X.astype(float)
    final_model = sm.OLS(y, final_X).fit()
    return final_model, selected_features

final_model, selected_features = backward_elimination(X, Y, sl=0.05)
print(final_model.summary())
print('Selected features used in final model:')
print(selected_features)
print('Final R-squared:', final_model.rsquared)
